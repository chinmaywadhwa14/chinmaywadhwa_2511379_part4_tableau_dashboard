      <aliases enabled='yes' />
      <column caption='Profit Margin' datatype='real' name='[Calculation_0231601870643200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([profit]) / SUM([sales])' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_0231601870987265]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) - SUM([profit])' />
      </column>
      <column caption='Average Order Value' datatype='real' name='[Calculation_0231601871114242]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([sales]) / COUNTD([order_id])' />
      </column>
      <column caption='Return Rate' datatype='real' name='[Calculation_0231601871581187]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([return_flag]) / COUNT([order_id])' />
      </column>
      <column caption='Shipping Delay Bucket' datatype='string' name='[Calculation_0231601871667204]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [delivery_days] &lt;= 3 THEN &quot;Fast (0-3 Days)&quot;&#10;ELSEIF [delivery_days] &lt;= 6 THEN &quot;Medium (4-6 Days)&quot;&#10;ELSE &quot;Slow (7+ Days)&quot;&#10;END' />
      </column>
